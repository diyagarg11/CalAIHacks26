# Copy to .env and fill in. The diagnostic assessment works WITHOUT a key;
# only the multimodal content pipeline (/api/content/generate) needs one.
ANTHROPIC_API_KEY=

# Deepgram powers the audio lesson narration (text-to-speech) and the
# voice-answer transcription (speech-to-text) in the diagnostic.
DEEPGRAM_API_KEY=

# Optional overrides
PORT=8787
# Model for the multimodal content pipeline (defaults to claude-opus-4-8)
CONTENT_MODEL=claude-opus-4-8
# Deepgram voices/models (defaults shown)
TTS_MODEL=aura-2-thalia-en
STT_MODEL=nova-3
